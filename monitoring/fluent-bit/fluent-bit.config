[SERVICE]
    Flush         1
    Daemon        Off
    Log_Level     info
    Parsers_File  parsers.conf

[INPUT]
    Name              tail
    Path              /var/lib/docker/containers/*/*.log
    Parser            docker
    Tag               docker.*
    Refresh_Interval  5
    Mem_Buf_Limit     5MB
    Skip_Long_Lines   On

# only ship rag-api logs
[FILTER]
    Name    grep
    Match   docker.*
    Regex   log rag-api

# add labels
[FILTER]
    Name    record_modifier
    Match   docker.*
    Record  service rag-api
    Record  environment local

# ship to Loki
[OUTPUT]
    Name            loki
    Match           docker.*
    Host            loki
    Port            3100
    Labels          job=rag-api,env=local
    Auto_Kubernetes_Labels off
